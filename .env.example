# Database
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/ecommerce_dev?schema=public"


# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.kmfbkdyvdenwxqclywcl:your_password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.kmfbkdyvdenwxqclywcl:your_password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Application
APP_NAME='NestJS Ecommerce Platform'
NODE_ENV=development

# JWT Configuration - CHANGE THESE IN PRODUCTION!
ACCESS_TOKEN_SECRET='your_access_token_secret_here_min_32_chars'
ACCESS_TOKEN_EXPIRES_IN='15m'
REFRESH_TOKEN_SECRET='your_refresh_token_secret_here_min_32_chars'
REFRESH_TOKEN_EXPIRES_IN='7d'

# Payment API
PAYMENT_API_KEY=your_payment_api_key_here

# Admin Credentials - CHANGE THESE IN PRODUCTION!
ADMIN_NAME='Admin'
ADMIN_PASSWORD=change_this_password_in_production
ADMIN_EMAIL=admin@example.com
ADMIN_PHONENUMBER=0000000000

# OTP Configuration
OTP_EXPIRES_IN=5m

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_REDIRECT_URI=http://localhost:3300/oauth-google-callback

# Static Files
PREFIX_STATIC_ENDPOINT=http://localhost:3000/media/static

# AWS S3 Configuration
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=your_aws_access_key_id
S3_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET_NAME=your-bucket-name

# VNData Cloud Storage (Optional)
VNDATA_REGION=hcm
VNDATA_ACCESS_KEY_ID=your_vndata_access_key
VNDATA_SECRET_ACCESS_KEY=your_vndata_secret_key
VNDATA_CLOUD_STORAGE=
VNDATA_S3_ENDPOINT=https://s3-hcm-r2.s3cloud.vn

# AI Service
ANTHROPIC_API_KEY=your_anthropic_api_key

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://default:your_redis_password@localhost:6379

# MUX Video Configuration
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_ENDPOINT=your_mux_webhook_endpoint
MUX_SIGNING_SECRET=your_mux_signing_secret

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3300,http://localhost:5173
